# =============================================================================
# AI Codebase Audit - Environment Configuration
# =============================================================================
# Copy this file to .env:  cp .env.example .env
#
# AUDIT_BASE_DIR is the PARENT directory that contains:
#   1. config.yml         (audit configuration)
#   2. CLAUDE.md          (Claude agent instructions)
#   3. .claude/           (skills and agents directory)
#   4. project-one/       (your actual project directories to audit)
#   5. project-two/       (another project directory)
#   6. logs/              (created automatically - analysis logs)
#
# Example directory structure:
#
#   /Users/you/code-audits/              ← Set AUDIT_BASE_DIR to this path
#     ├── config.yml                     ← Configure which projects & skills
#     ├── CLAUDE.md                      ← Agent instructions (provided)
#     ├── .claude/                       ← Skills & agents (provided)
#     │   ├── settings.json
#     │   ├── agents/
#     │   └── skills/
#     ├── my-java-app/                   ← Your project #1
#     │   ├── src/
#     │   ├── pom.xml
#     │   └── .analysis/java/            ← Results written here
#     ├── my-react-app/                  ← Your project #2
#     │   ├── src/
#     │   ├── package.json
#     │   └── .analysis/javascript/      ← Results written here
#     └── logs/                          ← Audit logs (auto-created)
#         ├── docker_<timestamp>.log
#         ├── python_<timestamp>.log
#         ├── summary_<timestamp>.txt
#         └── result_*.txt
#
# =============================================================================

# =============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# =============================================================================

# Set this to the PARENT directory containing config.yml, CLAUDE.md, .claude/,
# and your project directories (NOT a single project directory)
AUDIT_BASE_DIR=/absolute/path/to/your/audit-parent-directory

# Your Anthropic API key
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# =============================================================================
# OPTIONAL ENVIRONMENT VARIABLES (DevContainer-specific)
# =============================================================================

# Force rebuild of Docker image on every run
# When true: Rebuilds image from .devcontainer/Dockerfile even if it exists
# When false: Uses cached image if available (faster startup)
# Useful after modifying Dockerfile or when troubleshooting build issues
# Default: false
# Alternative: Set runner.rebuild: true in config.yml
FORCE_REBUILD=false
