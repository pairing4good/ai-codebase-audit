{
  "_comment_security": "SECURITY MODEL: This runner uses bypassPermissions mode for autonomous operation. The permissions below provide defense-in-depth by restricting file access and dangerous operations. Skills can READ source code but CANNOT modify it - only .analysis/ is writable.",
  "permissions": {
    "allow": [
      "Read(*)",
      "Grep(*)",
      "Glob(*)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(mvn *)",
      "Bash(gradle *)",
      "Bash(java *)",
      "Bash(dotnet *)",
      "Bash(eslint *)",
      "Bash(sonar-scanner *)",
      "Bash(spotbugs *)",
      "Bash(pmd *)",
      "Write(.analysis/**)",
      "Write(ANALYSIS-REPORT.md)",
      "Write(ARCHITECTURE-OVERVIEW.md)",
      "Write(FINDINGS-DETAILED.json)",
      "Write(CONFIDENCE-MATRIX.md)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env*)",
      "Read(**/credentials.json)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*secret*)",
      "Read(**/*password*)",
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)",
      "Bash(telnet *)",
      "Bash(ftp *)",
      "Write(.claude/**)",
      "Write(.git/**)",
      "Write(../**)",
      "Write(src/**)",
      "Write(lib/**)",
      "Write(app/**)",
      "Write(config/**)",
      "Write(**/*.java)",
      "Write(**/*.js)",
      "Write(**/*.ts)",
      "Write(**/*.py)",
      "Write(**/*.cs)",
      "Write(**/*.go)",
      "Write(**/*.rb)",
      "Write(**/*.php)",
      "Edit(src/**)",
      "Edit(lib/**)",
      "Edit(app/**)",
      "Edit(**/*.java)",
      "Edit(**/*.js)",
      "Edit(**/*.ts)",
      "Edit(**/*.py)",
      "Edit(**/*.cs)"
    ]
  },
  "env": {
    "ANALYSIS_OUTPUT_DIR": "${CLAUDE_PROJECT_DIR}/.analysis",
    "SEVERITY_THRESHOLD": "medium",
    "CONFIDENCE_THRESHOLD": "medium",
    "MAX_FINDINGS_PER_AGENT": "50",
    "ENABLE_GIT_CHURN_ANALYSIS": "true",
    "PARALLEL_AGENT_EXECUTION": "true"
  },
  "defaultModel": "sonnet",
  "alwaysThinkingEnabled": false,
  "sandbox": {
    "_comment": "Sandbox provides additional protection. Network is disabled to prevent data exfiltration. Filesystem access is limited to read-only for source code, write-only for .analysis/",
    "enabled": true,
    "allowNetwork": false,
    "allowFilesystem": true,
    "readOnlyPaths": ["src", "lib", "app", "test", "tests"],
    "writablePaths": [".analysis"]
  },
  "todoMode": "auto",
  "hooks": {
    "pre-audit": "git status --porcelain | wc -l",
    "post-audit": "echo 'Analysis complete. Review ANALYSIS-REPORT.md for findings.'"
  }
}
