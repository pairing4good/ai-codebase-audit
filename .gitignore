# AI Codebase Audit System - .gitignore

# Claude Code local configurations
.claude/settings.local.json
.claude/worktrees/
.claude/*.local.*
.claude/sessions/

# Analysis outputs (when running audit on this repo itself)
.analysis/
ANALYSIS-REPORT.md
ARCHITECTURE-OVERVIEW.md
FINDINGS-DETAILED.json
CONFIDENCE-MATRIX.md

# Static analysis tool outputs
.sonarqube/
.scannerwork/
coverage/
node_modules/
.npm/
*.log

# IDE and OS files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build outputs
dist/
build/
out/
target/
bin/
obj/

# Environment and secrets
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json

# Temporary files
tmp/
temp/
*.tmp
